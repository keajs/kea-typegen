#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
TMP_ROOT=${TMPDIR:-/tmp}
CALLER_PWD=$(pwd)

GOCACHE=${GOCACHE:-"$TMP_ROOT/kea-typegen-gocache"}
GOMODCACHE=${GOMODCACHE:-"$TMP_ROOT/kea-typegen-gomodcache"}

mkdir -p "$GOCACHE" "$GOMODCACHE"

export KEA_TYPEGEN_CWD="$CALLER_PWD"
export GOCACHE
export GOMODCACHE

cd "$REPO_ROOT/rewrite"
exec go run ./cmd/kea-typegen-go "$@"
